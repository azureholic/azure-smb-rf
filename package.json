{
  "name": "azure-smb-ready-foundation",
  "version": "0.3.0",
  "description": "Azure SMB Ready Foundation - repeatable single-subscription Azure environment for Microsoft Partners migrating SMB customers from on-premises to Azure.",
  "private": true,
  "scripts": {
    "prepare": "lefthook install",
    "lint:md": "markdownlint-cli2 '**/*.md' '#node_modules'",
    "lint:md:fix": "markdownlint-cli2 --fix '**/*.md' '#node_modules'",
    "lint:links": "find . -name '*.md' ! -path '*/node_modules/*' ! -path '*/.git/*' | xargs -I {} markdown-link-check {} --config .markdown-link-check.json",
    "lint:json": "node scripts/lint-json.mjs",
    "lint:drawio": "node scripts/validate-drawio-files.mjs",
    "lint:excalidraw": "node scripts/validate-excalidraw-files.mjs",
    "lint:h2-sync": "node scripts/validate-artifacts.mjs",
    "lint:governance-refs": "node scripts/validate-governance-refs.mjs",
    "lint:model-alignment": "node scripts/lint-model-alignment.mjs",
    "lint:artifact-templates": "node scripts/validate-artifact-templates.mjs",
    "lint:cost-estimate-templates": "node scripts/validate-cost-estimate-templates.mjs",
    "lint:terraform-fmt": "terraform fmt -check -recursive",
    "lint:python": "python3 -m flake8 scripts/ mcp/ --exclude=.venv",
    "validate:agents": "node scripts/validate-agents.mjs",
    "validate:agent-registry": "node scripts/validate-agent-registry.mjs",
    "validate:artifacts": "node scripts/validate-artifacts.mjs",
    "validate:drawio": "node scripts/validate-drawio-files.mjs",
    "validate:excalidraw": "node scripts/validate-excalidraw-files.mjs",
    "validate:glob-audit": "node scripts/validate-glob-audit.mjs",
    "validate:governance-refs": "node scripts/validate-governance-refs.mjs",
    "validate:hooks": "node scripts/validate-hooks.mjs",
    "validate:iac-security-baseline": "node scripts/validate-iac-security-baseline.mjs",
    "validate:instruction-checks": "node scripts/validate-instruction-checks.mjs",
    "validate:mcp-config": "node scripts/validate-mcp-config.mjs",
    "validate:no-deprecated-refs": "node scripts/validate-no-deprecated-refs.mjs",
    "validate:no-hardcoded-counts": "node scripts/validate-no-hardcoded-counts.mjs",
    "validate:orphaned-content": "node scripts/validate-orphaned-content.mjs",
    "validate:session-lock": "node scripts/validate-session-lock.mjs",
    "validate:session-state": "node scripts/validate-session-state.mjs",
    "validate:skill-checks": "node scripts/validate-skill-checks.mjs",
    "validate:skills": "node scripts/validate-skills.mjs",
    "validate:terminology": "node scripts/validate-terminology.mjs",
    "validate:version-sync": "node scripts/validate-version-sync.mjs",
    "validate:vscode-config": "node scripts/validate-vscode-config.mjs",
    "validate:workflow-graph": "node scripts/validate-workflow-graph.mjs",
    "validate:terraform": "terraform validate",
    "validate:all": "node scripts/validate-agents.mjs && node scripts/validate-agent-registry.mjs && node scripts/validate-artifacts.mjs && node scripts/validate-hooks.mjs && node scripts/validate-mcp-config.mjs && node scripts/validate-no-hardcoded-counts.mjs && node scripts/validate-no-deprecated-refs.mjs && node scripts/validate-governance-refs.mjs && node scripts/validate-skills.mjs && node scripts/validate-instruction-checks.mjs && node scripts/validate-version-sync.mjs && node scripts/validate-vscode-config.mjs && node scripts/validate-workflow-graph.mjs && node scripts/validate-terminology.mjs && node scripts/lint-json.mjs && node scripts/validate-drawio-files.mjs && node scripts/validate-excalidraw-files.mjs && node scripts/validate-session-state.mjs"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "fast-xml-parser": "^5.6.0",
    "lefthook": "^1.6.0",
    "markdown-link-check": "^3.12.0",
    "markdownlint-cli2": "^0.20.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jonathan-vella/azure-smb-rf.git"
  },
  "keywords": [
    "azure",
    "bicep",
    "smb",
    "landing-zone",
    "microsoft-partner",
    "infrastructure-as-code",
    "azure-migrate",
    "azure-verified-modules"
  ],
  "author": "Jonathan Vella",
  "license": "MIT"
}
